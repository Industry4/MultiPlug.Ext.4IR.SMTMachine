@model MultiPlug.Base.Http.EdgeApp
@functions
{
    string DrawTickCross(bool theValue)
    {
        return (theValue) ? "<i class=\"icon-ok icon-large\"></i>" : "<i class=\"icon-remove icon-large\"></i>";
    }

    string isSelected(bool theValue, bool theCurrentValue)
    {
        return (theValue == theCurrentValue) ? "selected" : "";
    }
}
<form action="" method="post" accept-charset="utf-8" enctype="application/x-www-form-urlencoded" autocomplete="off">
    <section class="row-fluid">
        <div class="row-fluid">
            <div class="box">
                <div class="span4">
                </div>
                <div class="span4">
                    <p style="font-size:26px; line-height: 54px; text-align: center; margin: 0px;">SMT Machine Mimic</p>
                </div>
                <div class="span4" style="text-align: right;">
                    <button type="submit" value="submit" style="height:54px; width:65px" class="item btn btn-green"><i class="icon-save icon-large"></i><p>Save</p></button>
                </div>
            </div>
        </div>
        <div class="row-fluid">
            <ul class="nav nav-tabs">
                <li class="active"><a href="@Raw(Model.Context.Paths.Home)">Home</a></li>
                <li class=""><a href="@Raw(Model.Context.Paths.Home)about">About</a></li>
            </ul>
        </div>
        <div class="row-fluid">
            <h3 class="box-header">SMEMA Upstream</h3>
            <div class="box non-collapsible">
                <h4>SMEMA Machine Ready to Receive Event</h4>
                <div class="row-fluid">
                    <div class="well">
                        <div class="row-fluid">
                            <div class="span4">
                                <div class="row-fluid"><div class="span12"><b>Event ID</b></div></div>
                                <div class="row-fluid">
                                    <div class="span12">
                                        <input name="MachineReadyEventId" class="input-block-level" type="text" placeholder="Event ID" value="@Model.Extension.Model.MachineReadyEventId">
                                    </div>
                                </div>
                            </div>
                            <div class="span4">
                                <div class="span12">
                                    <div class="row-fluid"><div class="span12"><b>Event Description</b></div></div>
                                    <div class="row-fluid">
                                        <div class="span12">
                                            <input name="MachineReadyEventDescription" class="input-block-level" type="text" placeholder="Description" value="@Model.Extension.Model.MachineReadyEventDescription" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="span4">
                                <div class="row-fluid"><div class="span12"><b>Event Subject</b></div></div>
                                <div class="row-fluid">
                                    <div class="span12">
                                        <input name="MachineReadyEventSubject" class="span12" type="text" value="@Model.Extension.Model.MachineReadyEventSubject">
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row-fluid">
                            <div class="span4">
                                <div class="row-fluid"><div class="span12"><b>Ready Value</b></div></div>
                                <div class="row-fluid">
                                    <div class="span12">
                                        <input name="MachineReadyEventReadyValue" class="input-block-level" type="text" placeholder="Event ID" value="@Model.Extension.Model.MachineReadyEventReadyValue">
                                    </div>
                                </div>
                            </div>

                            <div class="span4">
                                <div class="span12">
                                    <div class="row-fluid"><div class="span12"><b>Not Ready Value</b></div></div>
                                    <div class="row-fluid">
                                        <div class="span12">
                                            <input name="MachineReadyEventNotReadyValue" class="input-block-level" type="text" placeholder="Description" value="@Model.Extension.Model.MachineReadyEventNotReadyValue" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <h4>SMEMA Good Board Available Subscription</h4>
                <div class="row-fluid">
                    <div class="well">
                        <div class="row-fluid">
                            <div class="span6">
                                <div class="row-fluid"><div class="span12"><b>Subscription ID</b></div></div>
                                <div class="row-fluid">
                                    <div class="span12">
                                        <input name="GoodBoardSubscriptionId" class="input-block-level mp-event-picker" type="text" value="@Model.Extension.Model.GoodBoardSubscriptionId" />
                                    </div>
                                </div>
                            </div>

                            <div class="span3">
                                <div class="row-fluid"><div class="span12"><b>Available Value</b></div></div>
                                <div class="row-fluid"><div class="span12"><input name="GoodBoardSubscriptionAvailableValue" class="input-block-level" type="text" value="@Model.Extension.Model.GoodBoardSubscriptionAvailableValue"></div></div>
                            </div>

                            <div class="span3">
                                <div class="row-fluid"><div class="span12"><b>Not Available Value</b></div></div>
                                <div class="row-fluid"><div class="span12"><input name="GoodBoardSubscriptionNotAvailableValue" class="input-block-level" type="text" value="@Model.Extension.Model.GoodBoardSubscriptionNotAvailableValue"></div></div>
                            </div>
                        </div>
                        <div class="row-fluid">
                            <div class="span3">
                                <div class="row-fluid"><div class="span12"><b>Connected</b></div></div>
                                <div class="row-fluid"><div class="span12">@Raw(DrawTickCross(@Model.Extension.Model.GoodBoardSubscriptionConnected))</div></div>
                            </div>
                        </div>
                    </div>
                </div>

                <h4>SMEMA Bad Board Available Subscription</h4>
                <div class="row-fluid">
                    <div class="well">
                        <div class="row-fluid">
                            <div class="span6">
                                <div class="row-fluid"><div class="span12"><b>Subscription ID</b></div></div>
                                <div class="row-fluid">
                                    <div class="span12">
                                        <input name="BadBoardSubscriptionId" class="input-block-level mp-event-picker" type="text" value="@Model.Extension.Model.BadBoardSubscriptionId" />
                                    </div>
                                </div>
                            </div>

                            <div class="span3">
                                <div class="row-fluid"><div class="span12"><b>Available Value</b></div></div>
                                <div class="row-fluid"><div class="span12"><input name="BadBoardSubscriptionAvailableValue" class="input-block-level" type="text" value="@Model.Extension.Model.BadBoardSubscriptionAvailableValue"></div></div>
                            </div>

                            <div class="span3">
                                <div class="row-fluid"><div class="span12"><b>Not Available Value</b></div></div>
                                <div class="row-fluid"><div class="span12"><input name="BadBoardSubscriptionNotAvailableValue" class="input-block-level" type="text" value="@Model.Extension.Model.BadBoardSubscriptionNotAvailableValue"></div></div>
                            </div>
                        </div>
                        <div class="row-fluid">
                            <div class="span3">
                                <div class="row-fluid"><div class="span12"><b>Connected</b></div></div>
                                <div class="row-fluid"><div class="span12">@Raw(DrawTickCross(@Model.Extension.Model.BadBoardSubscriptionConnected))</div></div>
                            </div>
                        </div>
                    </div>
                </div>

            </div>
        </div>

        <div class="row-fluid">
            <h3 class="box-header">SMEMA Downstream</h3>
            <div class="box non-collapsible">
                <h4>SMEMA Good Board Event</h4>
                <div class="row-fluid">
                    <div class="well">
                        <div class="row-fluid">
                            <div class="span4">
                                <div class="row-fluid"><div class="span12"><b>Event ID</b></div></div>
                                <div class="row-fluid">
                                    <div class="span12">
                                        <input name="GoodBoardAvailableEventId" class="input-block-level" type="text" placeholder="Event ID" value="@Model.Extension.Model.GoodBoardAvailableEventId">
                                    </div>
                                </div>
                            </div>
                            <div class="span4">
                                <div class="span12">
                                    <div class="row-fluid"><div class="span12"><b>Event Description</b></div></div>
                                    <div class="row-fluid">
                                        <div class="span12">
                                            <input name="GoodBoardAvailableEventDescription" class="input-block-level" type="text" placeholder="Description" value="@Model.Extension.Model.GoodBoardAvailableEventDescription" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="span4">
                                <div class="row-fluid"><div class="span12"><b>Event Subject</b></div></div>
                                <div class="row-fluid">
                                    <div class="span12">
                                        <input name="GoodBoardAvailableEventSubject" class="span12" type="text" value="@Model.Extension.Model.GoodBoardAvailableEventSubject">
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row-fluid">
                            <div class="span4">
                                <div class="row-fluid"><div class="span12"><b>Ready Value</b></div></div>
                                <div class="row-fluid">
                                    <div class="span12">
                                        <input name="GoodBoardAvailableEventAvailableValue" class="input-block-level" type="text" placeholder="Event ID" value="@Model.Extension.Model.GoodBoardAvailableEventAvailableValue">
                                    </div>
                                </div>
                            </div>

                            <div class="span4">
                                <div class="span12">
                                    <div class="row-fluid"><div class="span12"><b>Not Ready Value</b></div></div>
                                    <div class="row-fluid">
                                        <div class="span12">
                                            <input name="GoodBoardAvailableEventNotAvailableValue" class="input-block-level" type="text" placeholder="Description" value="@Model.Extension.Model.GoodBoardAvailableEventNotAvailableValue" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <h4>SMEMA Bad Board Event</h4>
                <div class="row-fluid">
                    <div class="well">
                        <div class="row-fluid">
                            <div class="span4">
                                <div class="row-fluid"><div class="span12"><b>Event ID</b></div></div>
                                <div class="row-fluid">
                                    <div class="span12">
                                        <input name="BadBoardAvailableEventId" class="input-block-level" type="text" placeholder="Event ID" value="@Model.Extension.Model.BadBoardAvailableEventId">
                                    </div>
                                </div>
                            </div>
                            <div class="span4">
                                <div class="span12">
                                    <div class="row-fluid"><div class="span12"><b>Event Description</b></div></div>
                                    <div class="row-fluid">
                                        <div class="span12">
                                            <input name="BadBoardAvailableEventDescription" class="input-block-level" type="text" placeholder="Description" value="@Model.Extension.Model.BadBoardAvailableEventDescription" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                            <div class="span4">
                                <div class="row-fluid"><div class="span12"><b>Event Subject</b></div></div>
                                <div class="row-fluid">
                                    <div class="span12">
                                        <input name="BadBoardAvailableEventSubject" class="span12" type="text" value="@Model.Extension.Model.BadBoardAvailableEventSubject">
                                    </div>
                                </div>
                            </div>
                        </div>

                        <div class="row-fluid">
                            <div class="span4">
                                <div class="row-fluid"><div class="span12"><b>Ready Value</b></div></div>
                                <div class="row-fluid">
                                    <div class="span12">
                                        <input name="BadBoardAvailableEventAvailableValue" class="input-block-level" type="text" placeholder="Event ID" value="@Model.Extension.Model.BadBoardAvailableEventAvailableValue">
                                    </div>
                                </div>
                            </div>

                            <div class="span4">
                                <div class="span12">
                                    <div class="row-fluid"><div class="span12"><b>Not Ready Value</b></div></div>
                                    <div class="row-fluid">
                                        <div class="span12">
                                            <input name="BadBoardAvailableEventNotAvailableValue" class="input-block-level" type="text" placeholder="Description" value="@Model.Extension.Model.BadBoardAvailableEventNotAvailableValue" />
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <h4>SMEMA Machine Ready Subscription</h4>
                <div class="row-fluid">
                    <div class="well">
                        <div class="row-fluid">
                            <div class="span6">
                                <div class="row-fluid"><div class="span12"><b>Subscription ID</b></div></div>
                                <div class="row-fluid">
                                    <div class="span12">
                                        <input name="MachineReadySubscriptionId" class="input-block-level mp-event-picker" type="text" value="@Model.Extension.Model.MachineReadySubscriptionId" />
                                    </div>
                                </div>
                            </div>

                            <div class="span3">
                                <div class="row-fluid"><div class="span12"><b>Available Value</b></div></div>
                                <div class="row-fluid"><div class="span12"><input name="MachineReadySubscriptionAvailableValue" class="input-block-level" type="text" value="@Model.Extension.Model.MachineReadySubscriptionAvailableValue"></div></div>
                            </div>

                            <div class="span3">
                                <div class="row-fluid"><div class="span12"><b>Not Available Value</b></div></div>
                                <div class="row-fluid"><div class="span12"><input name="MachineReadySubscriptionNotAvailableValue" class="input-block-level" type="text" value="@Model.Extension.Model.MachineReadySubscriptionNotAvailableValue"></div></div>
                            </div>
                        </div>
                        <div class="row-fluid">
                            <div class="span3">
                                <div class="row-fluid"><div class="span12"><b>Connected</b></div></div>
                                <div class="row-fluid"><div class="span12">@Raw(DrawTickCross(@Model.Extension.Model.MachineReadySubscriptionConnected))</div></div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</form>