@model MultiPlug.Base.Http.EdgeApp

<link rel="stylesheet" type="text/css" href="@Raw(Model.Context.Paths.Assets)css/settings.min.css">
<div class="row-fluid hermes-heading">
    <div class="box">
        <div class="span4">
        </div>
        <div class="span4">
            <p style="font-size:26px; line-height: 54px; text-align: center; margin: 0px;">SMT Machine Mimic</p>
        </div>
        <div class="span4" style="text-align: right;">
        </div>
    </div>
</div>

<section class="row-fluid">

    <div class="row-fluid">
        <ul class="nav nav-tabs">
            <li class=""><a href="@Raw(Model.Context.Paths.Home)">Home</a></li>
            <li class="active"><a href="@Raw(Model.Context.Paths.Home)about">About</a></li>
        </ul>
    </div>

    <div class="row-fluid">
        <div class="span12">
            <h3 class="box-header">Current Version</h3>
            <div class="box non-collapsible">
                <div class="row-fluid">
                    <div class="span6"><b>Version</b></div>
                    <div class="span6">@Raw(Model.Extension.Model.Version)</div>
                </div>
                <div class="row-fluid">
                    <div class="span6"><b>Extension</b></div>
                    <div class="span6">@Raw(Model.Extension.Model.Title)</div>
                </div>
                <div class="row-fluid">
                    <div class="span6"><b>Description</b></div>
                    <div class="span6">@Raw(Model.Extension.Model.Description)</div>
                </div>
                <div class="row-fluid">
                    <div class="span6"><b>Maintainer</b></div>
                    <div class="span6"><a target="_blank" href="https://www.4ir.uk">@Raw(Model.Extension.Model.Company)</a></div>
                </div>
                <div class="row-fluid">
                    <div class="span6"><b>Product</b></div>
                    <div class="span6">@Raw(Model.Extension.Model.Product)</div>
                </div>
                <div class="row-fluid">
                    <div class="span6"><b>Copyright</b></div>
                    <div class="span6">@Raw(Model.Extension.Model.Copyright)</div>
                </div>
                <div class="row-fluid">
                    <div class="span6"><b>Trademarks</b></div>
                    <div class="span6">@Raw(Model.Extension.Model.Trademark)</div>
                </div>
                <div class="row-fluid">
                    <div class="span6"><b>More information</b></div>
                    <div class="span6"><a target="_blank" href="https://github.com/Industry4/MultiPlug.Ext.4IR.SMTMachine/wiki">github.com/Industry4/MultiPlug.Ext.4IR.SMTMachine/wiki</a></div>
                </div>
                <div class="row-fluid">
                    <div class="span12">
                        <p>Copyright 2026 Industry4 Ltd trading as 4IR.UK British Systems</p>
                        <p>THE SOFTWARE IS PROVIDED "AS IS", WITHOUT WARRANTY OF ANY KIND, EXPRESS OR IMPLIED, INCLUDING BUT NOT LIMITED TO THE WARRANTIES OF MERCHANTABILITY, FITNESS FOR A PARTICULAR PURPOSE AND NONINFRINGEMENT. IN NO EVENT SHALL THE AUTHORS OR COPYRIGHT HOLDERS BE LIABLE FOR ANY CLAIM, DAMAGES OR OTHER LIABILITY, WHETHER IN AN ACTION OF CONTRACT, TORT OR OTHERWISE, ARISING FROM, OUT OF OR IN CONNECTION WITH THE SOFTWARE OR THE USE OR OTHER DEALINGS IN THE SOFTWARE.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>